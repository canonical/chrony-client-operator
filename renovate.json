{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "fileMatch": [
        "^charmcraft\\.yaml$"
      ],
      "matchStrings": [
        "source-tag: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "packageNameTemplate": "SuperQ/chrony_exporter"
    }
  ],
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "enabled": true,
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "enabled": false,
      "matchFileNames": [
        "rockcraft.yaml"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ]
    }
  ],
  "schedule": [
    "* * * * 0,6"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
